  "https://automiq-agents.onrender.com/openapi.json": {
    "status": 200,
    "body": {
      "openapi": "3.1.0",
      "info": {
        "title": "Automiq Agency Agents",
        "description": "Wrapper Hermes-style con MiniMax-M3 para los agentes de Automiq",
        "version": "0.1.0"
      },
      "paths": {
        "/healthz": {
          "get": {
            "summary": "Healthz",
            "operationId": "healthz_healthz_get",
            "responses": {
              "200": {
                "description": "Successful Response",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/HealthResponse"
                    }
                  }
                }
              }
            }
          }
        },
        "/agents": {
          "get": {
            "summary": "List Agents Endpoint",
            "operationId": "list_agents_endpoint_agents_get",
            "responses": {
              "200": {
                "description": "Successful Response",
                "content": {
                  "application/json": {
                    "schema": {
                      "items": {
                        "$ref": "#/components/schemas/AgentInfo"
                      },
                      "type": "array",
                      "title": "Response List Agents Endpoint Agents Get"
                    }
                  }
                }
              }
            }
          }
        },
        "/agents/{name}": {
          "get": {
            "summary": "Get Agent Endpoint",
            "operationId": "get_agent_endpoint_agents__name__get",
            "parameters": [
              {
                "name": "name",
                "in": "path",
                "required": true,
                "schema": {
                  "type": "string",
                  "title": "Name"
                }
              }
            ],
            "responses": {
              "200": {
                "description": "Successful Response",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/AgentInfo"
                    }
                  }
                }
              },
              "422": {
                "description": "Validation Error",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/HTTPValidationError"
                    }
                  }
                }
              }
            }
          }
        },
        "/scheduler/jobs": {
          "get": {
            "summary": "Scheduler Jobs",
            "operationId": "scheduler_jobs_scheduler_jobs_get",
            "responses": {
              "200": {
                "description": "Successful Response",
                "content": {
                  "application/json": {
                    "schema": {}
                  }
                }
              }
            }
          }
        },
        "/run/{name}": {
          "post": {
            "summary": "Run Agent Endpoint",
            "description": "Dispara un agente manualmente. Soporta async (devuelve run_id) o sync (espera output).",
            "operationId": "run_agent_endpoint_run__name__post",
            "parameters": [
              {
                "name": "name",
                "in": "path",
                "required": true,
                "schema": {
                  "type": "string",
                  "title": "Name"
                }
              }
            ],
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/RunAgentRequest"
                  }
                }
              }
            },
            "responses": {
              "200": {
                "description": "Successful Response",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/RunAgentResponse"
                    }
                  }
                }
              },
              "422": {
                "description": "Validation Error",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/HTTPValidationError"
                    }
                  }
                }
              }
            }
          }
        },
        "/webhook/lead": {
          "post": {
            "summary": "Lead Webhook",
            "description": "Webhook genérico para nuevos leads (form de la landing, Typeform, etc.).\nToma el lead, dispara una versión 'on-demand' de LeadHunter para enriquecerlo\ny notifica a Discord.",
            "operationId": "lead_webhook_webhook_lead_post",
            "requestBody": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/LeadWebhookPayload"
                  }
                }
              },
              "required": true
            },
            "responses": {
              "202": {
                "description": "Successful Response",
                "content": {
                  "application/json": {
                    "schema": {}
                  }
                }
              },
              "422": {
                "description": "Validation Error",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/HTTPValidationError"
                    }
                  }
                }
              }
            }
          }
        },
        "/": {
          "get": {
            "summary": "Root",
            "operationId": "root__get",
            "responses": {
              "200": {
                "description": "Successful Response",
                "content": {
                  "application/json": {
                    "schema": {}
                  }
                }
              }
            }
          }
        }
      },
      "components": {
        "schemas": {
          "AgentInfo": {
            "properties": {
              "name": {
                "type": "string",
                "title": "Name"
              },
              "description": {
                "type": "string",
                "title": "Description"
              },
              "schedule": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Schedule"
              },
              "timezone": {
                "type": "string",
                "title": "Timezone"
              },
              "enabled": {
                "type": "boolean",
                "title": "Enabled"
              }
            },
            "type": "object",
            "required": [
              "name",
              "description",
              "schedule",
              "timezone",
              "enabled"
            ],
            "title": "AgentInfo"
          },
          "HTTPValidationError": {
            "properties": {
              "detail": {
                "items": {
                  "$ref": "#/components/schemas/ValidationError"
                },
                "type": "array",
                "title": "Detail"
              }
            },
            "type": "object",
            "title": "HTTPValidationError"
          },
          "HealthResponse": {
            "properties": {
              "status": {
                "type": "string",
                "title": "Status"
              },
              "version": {
                "type": "string",
                "title": "Version"
              },
              "services": {
                "type": "object",
                "title": "Services"
              }
            },
            "type": "object",
            "required": [
              "status",
              "version",
              "services"
            ],
            "title": "HealthResponse"
          },
          "LeadWebhookPayload": {
            "properties": {
              "name": {
                "type": "string",
                "title": "Name"
              },
              "email": {
                "type": "string",
                "title": "Email"
              },
              "company": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Company"
              },
              "phone": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Phone"
              },
              "message": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Message"
              },
              "source": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Source"
              },
              "extra": {
                "anyOf": [
                  {
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Extra"
              }
            },
            "type": "object",
            "required": [
              "name",
              "email"
            ],
            "title": "LeadWebhookPayload",
            "description": "Payload típico de un form de lead (Typeform, Tally, landing propia, etc.)."
          },
          "RunAgentRequest": {
            "properties": {
              "args": {
                "type": "object",
                "title": "Args"
              },
              "async_run": {
                "type": "boolean",
                "title": "Async Run",
                "default": true
              }
            },
            "type": "object",
            "title": "RunAgentRequest"
          },
          "RunAgentResponse": {
            "properties": {
              "run_id": {
                "type": "string",
                "title": "Run Id"
              },
              "agent": {
                "type": "string",
                "title": "Agent"
              },
              "status": {
                "type": "string",
                "title": "Status"
              },
              "output": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Output"
              }
            },
            "type": "object",
            "required": [
              "run_id",
              "agent",
              "status"
            ],
            "title": "RunAgentResponse"
          },
          "ValidationError": {
            "properties": {
              "loc": {
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                },
                "type": "array",
                "title": "Location"
              },
              "msg": {
                "type": "string",
                "title": "Message"
              },
              "type": {
                "type": "string",
                "title": "Error Type"
              }
            },
            "type": "object",
            "required": [
              "loc",
              "msg",
              "type"
            ],
            "title": "ValidationError"
          }
        }
      }
    }
  },
