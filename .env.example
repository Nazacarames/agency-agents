# ────────────────────────────────────────────────────────────
# Automiq Agency Agents — environment variables
# Copiá este archivo a .env y completá con tus credenciales reales.
# En Render, configurá estas mismas vars en el dashboard (Environment).
# ────────────────────────────────────────────────────────────

# MiniMax-M3 (modelo default: M3, fallback: M2.5 / M2.5-highspeed)
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_API_KEY=sk-cp-REEMPLAZAR
MINIMAX_MODEL_PRIMARY=MiniMax-M3
MINIMAX_MODEL_FALLBACKS=MiniMax-M2.5,MiniMax-M2.5-highspeed
MINIMAX_MAX_TOKENS=8192
MINIMAX_TIMEOUT_SECONDS=120

# Discord — webhook de NAZA (reemplazá con el webhook real del canal)
# Crear en Discord: Edit Channel → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REEMPLAZAR/REEMPLAZAR
DISCORD_DEFAULT_USERNAME=Automiq Agents
DISCORD_AVATAR_URL=https://i.imgur.com/REEMPLAZAR.png

# Scheduler / runtime
SCHEDULER_TIMEZONE=America/Buenos_Aires
SCHEDULER_ENABLED=true
GLOBAL_PAUSE=false                # equivalente al agency/control.json de OpenClaw

# Web service
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Auth simple para webhooks (generá un token aleatorio largo)
WEBHOOK_SECRET=REEMPLAZAR-CON-UUID-AZAR

# Render-specific (auto-inyectadas, no tocar)
RENDER_SERVICE_ID=
RENDER_EXTERNAL_URL=
